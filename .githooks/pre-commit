#!/usr/bin/env bash
set -euo pipefail

# Bilingual-docs sync check: DE ↔ EN must be staged together.

staged=$(git diff --cached --name-only)
fail=0

check_pair() {
  local a="$1" b="$2"
  local a_staged b_staged
  a_staged=$(echo "$staged" | grep -xF "$a" || true)
  b_staged=$(echo "$staged" | grep -xF "$b" || true)

  if [[ -n "$a_staged" && -z "$b_staged" ]]; then
    echo "bilingual-check: $a staged but $b missing — update both or use --no-verify to skip"
    fail=1
  fi
  if [[ -n "$b_staged" && -z "$a_staged" ]]; then
    echo "bilingual-check: $b staged but $a missing — update both or use --no-verify to skip"
    fail=1
  fi
}

check_pair "README.md"     "README.en.md"
check_pair "CHANGELOG.md"  "CHANGELOG.en.md"
check_pair "CONTRIBUTING.md" "CONTRIBUTING.en.md"

exit $fail
